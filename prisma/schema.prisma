generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Add the application's domain models here as the championship data model is defined.
model Participant {
  id      String             @id @default(nanoid(8))
  name    String
  players Player[]
  matches MatchParticipant[]
}

model Player {
  id        String   @id @default(nanoid(8))
  name      String
  team      String
  positions String[]
  overall   Int

  participantId String
  participant   Participant @relation(fields: [participantId], references: [id])

  events MatchEvent[]
}

model Match {
  id        String      @id @default(nanoid(8))
  type      MatchType
  status    MatchStatus
  startTime DateTime?
  endTime   DateTime?

  participants MatchParticipant[]
  events       MatchEvent[]
}

model MatchParticipant {
  id            String               @id @default(nanoid(8))
  matchId       String
  role          MatchParticipantRole
  participantId String
  score         Int?

  match       Match       @relation(fields: [matchId], references: [id])
  participant Participant @relation(fields: [participantId], references: [id])
}

model MatchEvent {
  id        String         @id @default(nanoid(8))
  matchId   String
  playerId  String
  eventType MatchEventType
  eventTime DateTime

  match  Match  @relation(fields: [matchId], references: [id])
  player Player @relation(fields: [playerId], references: [id])
}

enum MatchEventType {
  GOAL
  ASSIST
  YELLOW_CARD
  RED_CARD
}

enum MatchParticipantRole {
  HOME
  AWAY
}

enum MatchType {
  GROUP
  KNOCKOUT
}

enum MatchStatus {
  SCHEDULED
  ONGOING
  COMPLETED
}
